    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "gray-matter": "^4.0.3",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
